# Google Sign-In — create clients at console.cloud.google.com → APIs & Services → Credentials
# Web client  : type "Web application" — used by backend to verify the idToken
# Android     : type "Android" + package com.amparo.app + SHA-1 from keystore
#               → place google-services.json at android/app/google-services.json
# iOS         : type "iOS" + bundle ID com.amparo.app
#               → place GoogleService-Info.plist at ios/Amparo/GoogleService-Info.plist
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxx.apps.googleusercontent.com
