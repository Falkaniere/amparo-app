# Google Sign-In — see GOOGLE_SIGNIN_SETUP.md for step-by-step instructions
# Values come from the Firebase console after creating the project.
#
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID : Firebase → Project Settings → Web client ID
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID : Firebase → Project Settings → iOS client ID
#
# Also place these files at the repo root (gitignored):
#   google-services.json        ← from Firebase Android app
#   GoogleService-Info.plist    ← from Firebase iOS app
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxx.apps.googleusercontent.com
