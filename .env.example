# Backend API
# Desenvolvimento local:
EXPO_PUBLIC_API_URL=http://localhost:3000
# Staging (Railway):
# EXPO_PUBLIC_API_URL=https://amparo-backend-production.up.railway.app

# Supabase — use o mesmo projeto configurado no backend
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth (Web Client ID do Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com
